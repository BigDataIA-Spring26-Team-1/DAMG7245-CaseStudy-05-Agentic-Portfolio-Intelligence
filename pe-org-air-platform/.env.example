# ---- Snowflake ----
SNOWFLAKE_ACCOUNT=xxxxxx
SNOWFLAKE_USER=xxxxxx
SNOWFLAKE_PASSWORD=xxxxxx
SNOWFLAKE_WAREHOUSE=xxxxxx
SNOWFLAKE_DATABASE=xxxxxx
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_ROLE=

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_TTL_SECONDS=300

# ---- AWS / S3 (for health check) ----
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=

# ---- App ----
APP_NAME=pe-org-air-platform
APP_ENV=dev
LOG_LEVEL=INFO

# ---- SEC / EDGAR ----
SEC_USER_AGENT=PE-OrgAIR (Northeastern) yourname@northeastern.edu

# ---- RapidAPI / Glassdoor ----
RAPIDAPI_KEY=
GLASSDOOR_RAPIDAPI_HOST=glassdoor-real-time.p.rapidapi.com
GLASSDOOR_COMPANY_SEARCH_PATH=/companies/search
GLASSDOOR_REVIEWS_PATH=/companies/reviews
GLASSDOOR_REVIEWS_PAGE_SIZE=50
GLASSDOOR_CACHE_TO_DISK=true
GLASSDOOR_DISABLE_DISCOVERY_FALLBACK=false
GLASSDOOR_REVIEWS_COMPANY_ID_PARAM=companyId
GLASSDOOR_COMPANY_ID_MAP=

# ---- LLM ----
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENAI_MODEL=openai/gpt-4o-mini
GEMINI_MODEL=gemini/gemini-2.5-flash
LLM_REQUEST_TIMEOUT=60
LLM_MAX_RETRIES=2
LLM_JUSTIFICATION_MODEL=openai/gpt-4o-mini
LLM_JUSTIFICATION_FALLBACK_MODEL=gemini/gemini-2.5-flash
LLM_HYDE_MODEL=openai/gpt-4o-mini
LLM_HYDE_FALLBACK_MODEL=gemini/gemini-2.5-flash
LLM_IC_PREP_MODEL=openai/gpt-4o-mini
LLM_IC_PREP_FALLBACK_MODEL=gemini/gemini-2.5-flash
LLM_ANALYST_MODEL=openai/gpt-4o-mini
LLM_ANALYST_FALLBACK_MODEL=gemini/gemini-2.5-flash

# ---- Retrieval ----
CHROMA_PATH=./chroma
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ---- Results export ----
RESULTS_DIR=results
RESULTS_S3_PREFIX=results
RESULTS_PORTFOLIO_TICKERS=NVDA,JPM,WMT,GE,DG
RESULTS_LOCAL_COPY_ENABLED=true
RESULTS_UPLOAD_TO_S3=true

# Optional portfolio config for the CS1 facade.
# Preferred source is the Snowflake portfolios / portfolio_holdings tables.
# Example:
# CS1_PORTFOLIOS_JSON={"growth_fund_v":{"name":"Growth Fund V","fund_vintage":2024,"holdings":[{"ticker":"NVDA","enterprise_value_mm":125000.0,"entry_org_air":58.0,"entry_date":"2024-01-15"},{"ticker":"JPM","enterprise_value_mm":90000.0}]}}
CS1_PORTFOLIOS_JSON=
